# Simple Contact Book

contacts = {
    "Rahul": "9876543210",
    "Anita": "9123456780",
    "Ravi": "9988776655"
}

# Display all contacts
print("Contact List:")
for name, number in contacts.items():
    print(name, ":", number)

# Search contact
search = input("\nEnter name to search: ")

if search in contacts:
    print("Phone Number:", contacts[search])
else:
    print("Contact not found")
